{
  "name": "spades",
  "version": "1.0.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev:server": "node --watch --max-http-header-size=65536 server/index.js",
    "dev:client": "cd client && node --max-http-header-size=65536 node_modules/vite/bin/vite.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "cd client && npx vite build",
    "start": "node --max-http-header-size=65536 server/index.js",
    "test": "node --test server/tests/game.test.js server/tests/coverage.test.js server/tests/middleware.test.js",
    "test:client": "cd client && npx vitest run",
    "test:all": "npm test && npm run test:client"
  },
  "dependencies": {
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "csrf-csrf": "^4.0.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.19.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.20.0",
    "socket.io": "^4.7.4",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
